# ── App environment ─────────────────────────────────────────────
NEXT_PUBLIC_ENV=development

# ── Target chain ────────────────────────────────────────────────
# 11155111 = Ethereum Sepolia (testnet, current)
# 84532    = Base Sepolia    (testnet)
# 8453     = Base mainnet    (production)
NEXT_PUBLIC_CHAIN_ID=11155111

# ── Backend URLs ────────────────────────────────────────────────
# Leave BOTH empty to use built-in Next.js API routes on Netlify.
# Only set these if you run a separate Fastify backend server.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# ── WalletConnect ────────────────────────────────────────────────
# Get a free project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=2588910233967fa9ce4c62e8865399c3

# ── RPC endpoints ────────────────────────────────────────────────
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Ethereum Sepolia — use Alchemy/Infura for better reliability in production
NEXT_PUBLIC_ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Contract addresses (Ethereum Sepolia testnet) ────────────────
# These will be filled in after running: forge script Deploy --rpc-url $ETH_SEPOLIA_RPC_URL --broadcast
NEXT_PUBLIC_PRICE_FEED_ADDRESS=
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_SPOT_ENGINE_ADDRESS=
NEXT_PUBLIC_PERP_ENGINE_ADDRESS=

# ── Mock token addresses (Ethereum Sepolia testnet) ──────────────
# Populated by the deploy script output
NEXT_PUBLIC_MOCK_USDT_ADDRESS=
NEXT_PUBLIC_MOCK_BTC_ADDRESS=
NEXT_PUBLIC_MOCK_SOL_ADDRESS=
NEXT_PUBLIC_MOCK_DOGE_ADDRESS=
NEXT_PUBLIC_MOCK_AVAX_ADDRESS=
NEXT_PUBLIC_MOCK_LINK_ADDRESS=
NEXT_PUBLIC_MOCK_AERO_ADDRESS=

# ── Site metadata ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://basedex-app.netlify.app
