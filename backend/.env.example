# ============================================================
# BaseDEX Backend — Environment Variables
# Copy this file to .env for local development
# Export these vars on your Hostinger VPS for production
# ============================================================

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins
# Production: set to your Netlify domain(s)
# e.g. CORS_ORIGIN=https://basedex.fi,https://www.basedex.fi
CORS_ORIGIN=http://localhost:3000

# Database — Neon PostgreSQL (optional; used for trade history persistence)
# Get a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/basedex?sslmode=require

# Base RPC (for on-chain settlement broadcasting)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification
# Get at: https://basescan.org/myapikey
BASESCAN_API_KEY=

# Deployer wallet private key (NEVER commit the real key)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Contract addresses (populated after deployment)
VAULT_ADDRESS=
SPOT_ENGINE_ADDRESS=
PERP_ENGINE_ADDRESS=
PRICE_FEED_ADDRESS=

# CoinGecko API key (free tier is fine; Pro for higher rate limits)
# Get at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=
