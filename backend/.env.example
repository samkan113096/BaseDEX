# ── Server ────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ── Postgres (Railway) ─────────────────────────────────────────
# Copy from: Railway dashboard > Postgres service > Variables
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway

# ── Redis (Railway) ────────────────────────────────────────────
# Copy from: Railway dashboard > Redis service > Variables
REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all.
CORS_ORIGIN=https://your-site.netlify.app,http://localhost:3000
