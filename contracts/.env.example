# ============================================================
# BaseDEX Contracts — Environment Variables
# Copy this file to .env (NEVER commit .env with real keys)
# ============================================================

# Deployer private key — MUST have ETH/Base ETH for gas
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URLs
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification
# Get at: https://basescan.org/myapikey
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# Multi-sig address (for ownership transfer after deployment)
# Create a Gnosis Safe at https://app.safe.global (Base network)
MULTISIG_ADDRESS=0xYOUR_MULTISIG_ADDRESS

# Timelock delay in seconds (recommended: 172800 = 48 hours)
TIMELOCK_DELAY=172800
